ZAI_API_KEY=your_api_key_here
POLL_INTERVAL_MS=30000
DAYS_BACK=7

# Optional: Claude usage monitoring
# On macOS this is read automatically from Keychain if not set
CLAUDE_ACCESS_TOKEN=

# Optional: GitHub Copilot usage monitoring
# Auto-detected from opencode auth.json or gh CLI if not set
GITHUB_COPILOT_TOKEN=

# Optional: Gemini CLI usage monitoring
# Auto-detected from macOS Keychain (gemini-cli-oauth) or ~/.gemini/oauth_creds.json
GEMINI_OAUTH_TOKEN=
# Required for token auto-refresh: set to your Gemini CLI OAuth app credentials
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
